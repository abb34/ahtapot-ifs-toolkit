{
  "manifest_version": 3,
  "name": "Ahtapot — ERP Toolkit",
  "short_name": "Ahtapot",
  "version": "1.0.1",
  "description": "ERP consultant toolkit — Excel reports, custom templates, environment labels, cross-copy, sticky notes and data analysis.",
  "homepage_url": "https://github.com/abb34/ahtapot-ifs-toolkit",
  "minimum_chrome_version": "111",
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "injector.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "widget.js"
      ],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ahtapot — ERP Toolkit",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}